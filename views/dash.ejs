            y="250"
            width="120"
            height="80"
            rx="10"
          ></rect>
          <text x="445" y="295" font-size="12">Navanagar</text>
        </svg>
      </div>

      <div class="footer" id="t-footer">
        EcoVoice • Sustainability Hackathon MVP Dashboard
      </div>
    </div>
