      let lang = "en";

      function t(key) {
        return T[lang][key] || T["en"][key] || key;
      }

      function setLang(l) {
        lang = l;
        document
          .querySelectorAll(".lang-btn")
          .forEach((b) =>
            b.classList.toggle(
              "active",
              b.textContent.trim() === (l === "en" ? "English" : "ಕನ್ನಡ"),
            ),
          );
        applyTranslations();
        renderAll();
      }

      function applyTranslations() {
        const ids = [
          "title",
          "subtitle",
          "problems",
          "saving",
          "rank",
          "water",
          "elec",
          "waste",
          "water-desc",
          "elec-desc",
          "waste-desc",
          "score-title",
          "score-desc",
          "trend",
          "rankings",
          "col-rank",
          "col-community",
          "col-score",
          "col-status",
          "suggestions",
          "map",
          "leg-high",
          "leg-med",
          "leg-low",
          "footer",
        ];
        ids.forEach((id) => {
          const el = document.getElementById("t-" + id);
          if (el) el.textContent = t(id);
        });
      }

      // ─── UTILITY ───────────────────────────────────────────────────────────────
      function getState(score) {
        if (score < 40) return "red";
        if (score < 75) return "yellow";
        return "green";
      }

      function getStateLabel(score) {
        if (score < 40) return t("high");
        if (score < 75) return t("medium");
        return t("low");
      }

      function getBarColor(state) {
        return state === "red"
          ? "#dc2626"
          : state === "yellow"
            ? "#f59e0b"
            : "#1f7a4d";
      }

      // ─── RENDER SCORES ─────────────────────────────────────────────────────────
      function renderScores() {
        const keys = ["water", "elec", "waste"];
        const cardIds = ["card-water", "card-elec", "card-waste"];
        const badgeIds = ["badge-water", "badge-elec", "badge-waste"];
        const dispIds = [
          "score-water-display",
          "score-elec-display",
          "score-waste-display",
        ];
        const barIds = ["bar-water", "bar-elec", "bar-waste"];
        const scoreVals = [scores.water, scores.elec, scores.waste];

        scoreVals.forEach((s, i) => {
          const state = getState(s);
          const card = document.getElementById(cardIds[i]);
          card.className = "nav-card state-" + state;

          const badge = document.getElementById(badgeIds[i]);
          badge.textContent = getStateLabel(s);
          badge.className = "status " + state;

          document.getElementById(dispIds[i]).textContent = s + " / 100";

          const bar = document.getElementById(barIds[i]);
          bar.style.width = s + "%";
          bar.style.background = getBarColor(state);
        });

        function getEmoji(score) {
          if (score > 70) return "😊";
          if (score > 40) return "😐";
          return "⚠️";
        }

        // Community score
        const avg = Math.round((scores.water + scores.elec + scores.waste) / 3);
        const avgState = getState(avg);
        document.getElementById("community-score-display").innerHTML =
          avg + " " + getEmoji(avg);
        const panel = document.getElementById("panel-score");
        panel.className = "panel state-" + avgState;
      }

      async function renderRankings() {
        const res = await fetch("http://localhost:8080/rankings");
        const data = await res.json();

        const tbody = document.getElementById("rankings-body");
        tbody.innerHTML = "";

        data.forEach((c, i) => {
          const tr = document.createElement("tr");

          tr.innerHTML = `
      <td>#${i + 1}</td>
      <td>${c.zone}</td>
      <td>${c.score}</td>
      <td>${c.score > 70 ? "🟢" : c.score > 40 ? "🟡" : "🔴"}</td>
    `;

          tbody.appendChild(tr);
        });
      }

