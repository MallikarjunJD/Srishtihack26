<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DailyDrop Dashboard</title>
    <link rel="stylesheet" href="dash.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  </head>

  <body>
    <div class="wrapper">
      <!-- LANG TOGGLE -->
      <div class="lang-toggle">
        <button class="lang-btn active" onclick="setLang('en')">English</button>
        <button class="lang-btn" onclick="setLang('kn')">ಕನ್ನಡ</button>
      </div>

      <!-- TOP -->
      <div class="topbar">
        <div class="title">
          <h1 id="t-title">Dashboard</h1>
          <p id="t-subtitle">
            Community sustainability monitoring & volunteer accountability
            system
          </p>
        </div>

        <div class="mini-cards">
          <div class="mini">
            <h4 id="t-problems">Problems</h4>
            <strong>24</strong>
          </div>
          <div class="mini">
            <h4 id="t-saving">Estimated Saving</h4>
            <strong>520L</strong>
          </div>
          <div class="mini">
            <h4 id="t-rank">Ranking Community</h4>
            <strong>#03</strong>
          </div>
        </div>
      </div>

      <!-- GRID -->
      <div class="grid">
        <!-- LEFT NAVIGATION -->
        <div class="side">
          <div class="nav-card" id="card-water">
            <div class="nav-head">
              <h2>1️⃣ <span id="t-water">Water</span></h2>
              <span class="status" id="badge-water">–</span>
            </div>
            <p id="t-water-desc">
              Leakage reports, overflow taps, shared water misuse and urgent
              water complaints.
            </p>
            <strong id="score-water-display">–</strong>
            <div class="score-bar-wrap">
              <div class="score-bar-fill" id="bar-water"></div>
            </div>
          </div>

          <div class="nav-card" id="card-elec">
            <div class="nav-head">
              <h2>2️⃣ <span id="t-elec">Electricity</span></h2>
              <span class="status" id="badge-elec">–</span>
            </div>
            <p id="t-elec-desc">
              Street lights on in daytime, exposed lines, unnecessary power
              consumption.
            </p>
            <strong id="score-elec-display">–</strong>
            <div class="score-bar-wrap">
              <div class="score-bar-fill" id="bar-elec"></div>
            </div>
          </div>

          <div class="nav-card" id="card-waste">
            <div class="nav-head">
              <h2>3️⃣ <span id="t-waste">Material / Waste</span></h2>
              <span class="status" id="badge-waste">–</span>
            </div>
            <p id="t-waste-desc">
              Garbage overflow, recyclable waste, blocked disposal areas and
              cleanliness issues.
            </p>
            <strong id="score-waste-display">–</strong>
            <div class="score-bar-wrap">
              <div class="score-bar-fill" id="bar-waste"></div>
            </div>
          </div>
        </div>

        <!-- RIGHT CONTENT -->
        <div class="content">
          <!-- COMMUNITY SCORE -->
          <div class="panel" id="panel-score">
            <h2 id="t-score-title">🌍 Community Impact Score</h2>
            <div class="score-box">
              <div class="big-score" id="community-score-display">–</div>
              <p id="t-score-desc">
                Average of Water, Electricity and Waste scores. Based on issue
                reporting, problem resolution, volunteer participation and
                resource savings.
              </p>
            </div>
          </div>

          <!-- CHART -->
          <div class="panel">
            <h2 id="t-trend">📈 Weekly Problem Trend</h2>
            <canvas id="trendChart" height="110"></canvas>
          </div>

          <!-- COMMUNITY RANKINGS -->
          <div class="panel">
            <h2 id="t-rankings">🏆 Community Rankings & Our Standing</h2>
            <table>
              <thead>
                <tr>
                  <th id="t-col-rank">Rank</th>
                  <th id="t-col-community">Community</th>
                  <th id="t-col-score">Score</th>
                  <th id="t-col-status">Status</th>
                </tr>
              </thead>
              <tbody id="rankings-body"></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- SUGGESTIONS -->
      <div class="suggestion-panel" style="margin-top: 22px">
        <h2 id="t-suggestions">💡 Suggestions Based on Current Status</h2>
        <div class="suggestions-list" id="suggestions-list"></div>
      </div>

      <div class="map-panel" style="margin-top: 22px">
        <h2>🗺️ Hubli–Dharwad Zone Map</h2>

