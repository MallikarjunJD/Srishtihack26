      let currentUtterance = null;

      function speak(text, btnEl) {
        if (!window.speechSynthesis) return;
        window.speechSynthesis.cancel();
        if (btnEl.classList.contains("speaking")) {
          btnEl.classList.remove("speaking");
          btnEl.innerHTML = "🔊 Play";
          return;
        }
        document.querySelectorAll(".speak-btn").forEach((b) => {
          b.classList.remove("speaking");
          b.innerHTML = "🔊 Play";
        });
        const u = new SpeechSynthesisUtterance(text);
        u.lang = lang === "kn" ? "kn-IN" : "en-IN";
        u.onend = () => {
          btnEl.classList.remove("speaking");
          btnEl.innerHTML = "🔊 Play";
        };
        currentUtterance = u;
        btnEl.classList.add("speaking");
        btnEl.innerHTML = "⏹ Stop";
        window.speechSynthesis.speak(u);
      }

      function renderSuggestions() {
        const S = lang === "kn" ? suggestions_kn : suggestions_en;
        const avg = Math.round((scores.water + scores.elec + scores.waste) / 3);

        const waterState = getState(scores.water);
        const elecState = getState(scores.elec);
        const wasteState = getState(scores.waste);
        const avgState = getState(avg);

        const items = [];
        const wKey =
          waterState === "red"
            ? "water_low"
            : waterState === "yellow"
              ? "water_med"
              : "water_ok";
        const eKey =
          elecState === "red"
            ? "elec_low"
            : elecState === "yellow"
              ? "elec_med"
              : "elec_ok";
        const rKey =
          wasteState === "red"
            ? "waste_low"
            : wasteState === "yellow"
              ? "waste_med"
              : "waste_ok";
        const sKey =
          avgState === "red"
            ? "score_low"
            : avgState === "yellow"
              ? "score_med"
              : "score_ok";

        [...S[wKey], ...S[eKey], ...S[rKey], ...S[sKey]].forEach((msg) =>
          items.push(msg),
        );

        const list = document.getElementById("suggestions-list");
        list.innerHTML = "";
        items.forEach((msg) => {
          const cls =
            msg.includes("⚠️") ||
            msg.includes("💧") ||
            msg.includes("🔌") ||
            msg.includes("🗑️") ||
            msg.includes("♻️")
              ? "suggestion-item warn"
              : "suggestion-item";
          const div = document.createElement("div");
          div.className = cls;
          div.innerHTML = `<span>${msg}</span><button class="speak-btn" onclick="speak(this.previousElementSibling.textContent, this)">🔊 Play</button>`;
          list.appendChild(div);
        });
      }

      async function renderMap() {
        const res = await fetch("http://localhost:8080/zones");
        const zones = await res.json();

        zones.forEach((z) => {
          const id = "zone-" + z.name.toLowerCase().replace(/\s/g, "");
          const el = document.getElementById(id);

          if (!el) return;

          let color =
            z.score > 70 ? "#1f7a4d" : z.score > 40 ? "#f59e0b" : "#dc2626";

          el.style.fill = color;

          // Tooltip
          el.innerHTML = `<title>${z.name} - Score: ${z.score}</title>`;
        });
      }

      async function renderChart() {
        try {
          const res = await fetch("http://localhost:8080/trend");
          const data = await res.json();

          if (chartInstance) chartInstance.destroy();

          const ctx = document.getElementById("trendChart").getContext("2d");

          chartInstance = new Chart(ctx, {
            type: "line",
            data: {
              labels: [
                "Day 1",
                "Day 2",
                "Day 3",
                "Day 4",
                "Day 5",
                "Day 6",
                "Day 7",
              ],
              datasets: [
                {
                  label: "Water",
                  data: data.water || [],
                  borderWidth: 3,
                  tension: 0.4,
                  fill: true,
                },
                {
                  label: "Waste",
                  data: data.waste || [],
                  borderWidth: 3,
                  tension: 0.4,
                  fill: true,
                },
                {
                  label: "Electricity",
                  data: data.elec || [],
                  borderWidth: 3,
                  tension: 0.4,
                  fill: true,
                },
              ],
            },
            options: {
              responsive: true,
              plugins: {
                legend: {
                  labels: {
                    font: { size: 14 },
                  },
                },
              },
              scales: {
                y: {
                  beginAtZero: true,
                  max: 100,
                  ticks: {
                    stepSize: 20,
                  },
                },
              },
            },
          });
        } catch (err) {
          console.error("Chart error:", err);
        }
      }

      async function renderAll() {
        renderScores();
        await renderRankings();
        renderSuggestions();
        await renderMap();
        await renderChart();
      }

      function getVoiceMessage(score) {
        if (score >= 80)
          return "Excellent. Your community is saving resources efficiently.";

        if (score >= 60) return "Good performance. Focus on reducing waste.";

        if (score >= 40)
          return "Average performance. Improve water usage and segregation.";

        return "Critical level. Immediate action required to reduce resource waste.";
      }

      function speakScore() {
        fetch("http://localhost:8080/community")
          .then((res) => res.json())
          .then((data) => {
            const msg = `Community score is ${data.communityScore}`;
            speak(msg);
          });
      }

      function speakSummary() {
        fetch("http://localhost:8080/community")
          .then((res) => res.json())
          .then((data) => {
            const msg = `Community score ${data.communityScore}. Water ${data.water}. Waste ${data.waste}`;
            const u = new SpeechSynthesisUtterance(msg);
            u.lang = "en-IN";
            speechSynthesis.speak(u);
          });
      }

      document.addEventListener("DOMContentLoaded", () => {
        applyTranslations();
        fetchData();
        setInterval(fetchData, 5000);
      });
    </script>
  </body>
</html>
